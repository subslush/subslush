NODE_ENV=development
PORT=3001

# Database Configuration
DB_HOST=localhost
DB_PORT=6432
DB_DATABASE=subscription_platform
DB_USER=subscription_user
DB_PASSWORD=your_password_here
DB_IDLE_IN_TRANSACTION_TIMEOUT_MS=120000

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# Optional: leave unset to disable password reset redirects
PASSWORD_RESET_REDIRECT_URL=http://localhost:5173/auth/reset-password
APP_BASE_URL=http://localhost:5173

# Email Configuration
EMAIL_PROVIDER=console
EMAIL_FROM=no-reply@subslush.com
EMAIL_REPLY_TO=support@subslush.com
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_CONNECTION_TIMEOUT=10000
SMTP_GREETING_TIMEOUT=10000
SMTP_SOCKET_TIMEOUT=10000
PASSWORD_RESET_EMAIL_SUBJECT=Reset your password

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_RATE_LIMIT_DB=1
REDIS_TTL_DEFAULT=3600
REDIS_SESSION_TTL=86400
REDIS_MAX_RETRIES=3
REDIS_RETRY_DELAY=1000

# JWT Configuration
JWT_SECRET=your_super_secure_jwt_secret_minimum_32_characters_required
JWT_EXPIRY=86400
JWT_ALGORITHM=HS256

# Card Provider Configuration
STRIPE_ENABLED=true
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
PAY4BIT_ENABLED=false
PAY4BIT_PUBLIC_KEY=your_pay4bit_public_key
PAY4BIT_SECRET_KEY=your_pay4bit_secret_key
PAY4BIT_CALLBACK_URL=https://your-domain.com/api/v1/payments/pay4bit/callback
PAY4BIT_BASE_URL=https://api.pay4bit.net

# MaxMind minFraud Factors Configuration
MAXMIND_MINFRAUD_ENABLED=false
MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=
MAXMIND_MINFRAUD_ENDPOINT=https://minfraud.maxmind.com/minfraud/v2.0/factors
MAXMIND_TIMEOUT_MS=2500
MAXMIND_REVIEW_SCORE=45
MAXMIND_BLOCK_SCORE=80
MAXMIND_SIGNAL_LOOKBACK_DAYS=180
MAXMIND_REPEAT_HIGH_VALUE_MULTIPLIER=2.5
MAXMIND_REPEAT_HIGH_VALUE_ABSOLUTE_CENTS=20000
MAXMIND_REPEAT_FAST_MINUTES=10
MAXMIND_REPEAT_DORMANCY_DAYS=45

# Session Encryption
SESSION_ENCRYPTION_KEY=your_32_character_encryption_key_123
SESSION_IV_LENGTH=16
MAX_SESSIONS_PER_USER=5
SESSION_CLEANUP_INTERVAL=3600

# NOWPayments Configuration
NOWPAYMENTS_API_KEY=your_nowpayments_api_key
# Optional: sandbox key when NOWPAYMENTS_SANDBOX_MODE=true
NOWPAYMENTS_SANDBOX_API_KEY=
NOWPAYMENTS_IPN_SECRET=your_nowpayments_ipn_secret
NOWPAYMENTS_BASE_URL=https://api.nowpayments.io/v1
NOWPAYMENTS_SANDBOX_MODE=true
NOWPAYMENTS_WEBHOOK_URL=https://your-domain.com/api/v1/payments/webhook
NOWPAYMENTS_CURRENCY_CACHE_TTL=3600
NOWPAYMENTS_CURRENCY_LKG_TTL=86400
NOWPAYMENTS_CURRENCY_REFRESH_INTERVAL=900000

# FX Pricing Configuration
CURRENCYAPI_KEY=your_currencyapi_key
FX_ENGINE_ENABLED=false
FX_FETCH_JOB_ENABLED=false
FX_PUBLISH_JOB_ENABLED=false
FX_FETCH_SCHEDULE_CRON=0 0 * * *
FX_PUBLISH_SCHEDULE_CRON=59 23 * * 0
FX_RATE_STALE_MINUTES=1560
FX_RATE_MAX_STALE_MINUTES=2880
FX_ROUNDING_RULE_VERSION=2026-02-v1

# Catalog Pricing Configuration
CATALOG_DB_PRICING=true
COUPON_RESERVATION_MINUTES=30
CHECKOUT_ABANDON_TTL_MINUTES=30

# Payment Monitoring Configuration
PAYMENT_MONITORING_INTERVAL=30000
PAYMENT_MONITORING_BATCH_SIZE=50
PAYMENT_RETRY_ATTEMPTS=3
PAYMENT_RETRY_DELAY=5000

# Credit Allocation Settings
CREDIT_ALLOCATION_RATE=1.0
CREDIT_ALLOCATION_TIMEOUT=30000

# Refund Processing Configuration
REFUND_APPROVAL_REQUIRED=true
REFUND_PROCESSING_TIMEOUT=300000

# Background Jobs / Monitors
JOBS_ENABLED=true
PAYMENT_MONITORING_AUTO_START=true
SUBSCRIPTION_RENEWAL_INTERVAL=300000
SUBSCRIPTION_RENEWAL_LOOKAHEAD_MINUTES=4320
SUBSCRIPTION_RENEWAL_BATCH_SIZE=50
SUBSCRIPTION_RENEWAL_RETRY_MINUTES=60
SUBSCRIPTION_EXPIRY_INTERVAL=3600000
SUBSCRIPTION_REMINDER_INTERVAL=3600000
PIN_LOCKOUT_MONITOR_INTERVAL=300000
SUBSCRIPTION_DATA_QUALITY_INTERVAL=3600000
CONTEST_PRIZE_INTERVAL=86400000
VIRAL_METRICS_INTERVAL=86400000
