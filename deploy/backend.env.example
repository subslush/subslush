NODE_ENV=production
PORT=3001

APP_BASE_URL=https://subslush.com
PASSWORD_RESET_REDIRECT_URL=https://subslush.com/auth/reset-password

TIKTOK_PIXEL_ID=tiktok_pixel_id
TIKTOK_EVENTS_ACCESS_TOKEN=
TIKTOK_EVENTS_TEST_CODE=

TELEGRAM_ORDER_NOTIFICATIONS_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_ORDER_CHANNEL_ID=
TELEGRAM_HTTP_TIMEOUT_MS=10000
TELEGRAM_ORDER_NOTIFICATION_INTERVAL=60000
TELEGRAM_ORDER_NOTIFICATION_BATCH_SIZE=20
TELEGRAM_ORDER_NOTIFICATION_MAX_ATTEMPTS=10
TELEGRAM_ORDER_NOTIFICATION_RETRY_BASE_SECONDS=60
TELEGRAM_ORDER_NOTIFICATION_LOCK_TIMEOUT_SECONDS=300

# Background jobs / monitors
JOBS_ENABLED=true
PAYMENT_MONITORING_AUTO_START=true

DB_HOST=your-supabase-host
DB_PORT=5432
DB_DATABASE=postgres
DB_USER=postgres
DB_PASSWORD=your-db-password
PGSSLMODE=require

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_DB=0
REDIS_RATE_LIMIT_DB=1

JWT_SECRET=your-32+char-jwt-secret
JWT_EXPIRY=86400
JWT_ALGORITHM=HS256

STRIPE_ENABLED=true
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
PAY4BIT_ENABLED=false
PAY4BIT_PUBLIC_KEY=pk_live_xxx
PAY4BIT_SECRET_KEY=sk_live_xxx
PAY4BIT_CALLBACK_URL=https://api.subslush.com/api/v1/payments/pay4bit/callback
PAY4BIT_BASE_URL=https://api.pay4bit.net
PAYPAL_ENABLED=true
PAYPAL_CHECKOUT_ENABLED=false
PAYPAL_MODE=live
PAYPAL_CLIENT_ID=paypal_live_client_id
PAYPAL_CLIENT_SECRET=paypal_live_client_secret
# Required when using /api/v1/payments/paypal/webhook signature verification
PAYPAL_WEBHOOK_ID=paypal_webhook_id
PAYPAL_HTTP_TIMEOUT_MS=15000
ANTOM_ENABLED=false
ANTOM_ENVIRONMENT=production
ANTOM_CLIENT_ID=antom_client_id
ANTOM_PRIVATE_KEY=antom_merchant_private_key_base64
ANTOM_PUBLIC_KEY=antom_platform_public_key_base64
ANTOM_API_DOMAIN=https://open-sea-global.alipay.com
ANTOM_WEBHOOK_URL=https://api.subslush.com/api/v1/payments/antom/webhook
ANTOM_KEY_VERSION=1
ANTOM_REQUEST_TIMEOUT_MS=15000
ANTOM_WEBHOOK_MAX_SKEW_MS=300000
ANTOM_SERVICE_FEE_BPS=450
ANTOM_SERVICE_FEE_FIXED_USD_CENTS=25
ANTOM_TAX_INCLUDES_SERVICE_FEE=true
ANTOM_MERCHANT_REGION=GB
PAYOP_ANTOM_PENDING_PAYMENT_TTL_HOURS=72

NOWPAYMENTS_API_KEY=your-nowpayments-api-key
NOWPAYMENTS_IPN_SECRET=your-nowpayments-ipn-secret
NOWPAYMENTS_WEBHOOK_URL=https://api.subslush.com/api/v1/payments/webhook
NOWPAYMENTS_BASE_URL=https://api.nowpayments.io/v1
NOWPAYMENTS_SANDBOX_MODE=false

CURRENCYAPI_KEY=your-currencyapi-key
FX_ENGINE_ENABLED=false
FX_FETCH_JOB_ENABLED=false
FX_PUBLISH_JOB_ENABLED=false
FX_FETCH_SCHEDULE_CRON=0 0 * * *
FX_PUBLISH_SCHEDULE_CRON=59 23 * * 0
FX_RATE_STALE_MINUTES=1560
FX_RATE_MAX_STALE_MINUTES=2880
FX_ROUNDING_RULE_VERSION=2026-02-v1

COOKIE_SECRET=your-16+char-cookie-secret
SESSION_ENCRYPTION_KEY=exactly-32-chars-session-key
SESSION_IV_LENGTH=16
CREDENTIALS_ENCRYPTION_KEY=exactly-32-chars-credentials-key
CREDENTIALS_IV_LENGTH=12

EMAIL_PROVIDER=smtp
EMAIL_FROM=hello@subslush.com
SMTP_HOST=your-smtp-host
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
